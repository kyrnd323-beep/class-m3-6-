    function calculateDispersion() {
        const desc = document.getElementById('data-desc-2').value.trim() || "입력한 데이터";
        const valStr = document.getElementById('data-input-2').value;
        
        let arr = valStr.split(',').map(n => parseFloat(n.trim())).filter(n => !isNaN(n));
        if(arr.length === 0) return showModal("오류", "산포도를 구할 데이터가 올바르지 않습니다.");

        const n = arr.length;
        const mean = arr.reduce((a, b) => a + b, 0) / n;
        
        const variance = arr.reduce((acc, val) => acc + Math.pow(val - mean, 2), 0) / n;
        const stddev = Math.sqrt(variance);

        document.getElementById('dispersion-mean').innerText = mean.toFixed(1);
        document.getElementById('dispersion-variance').innerText = variance.toFixed(2);
        // 한글 루트 대신 수학 루트 기호 적용
        document.getElementById('dispersion-stddev').innerText = "√" + variance.toFixed(2) + " ≒ " + stddev.toFixed(2);

        updateCustomDispersionChart(arr, mean);

        const opinionArea = document.getElementById('student-opinion-2');
        opinionArea.value = `[나만의 산포도 데이터 분석]\n- 수집 자료: ${desc}\n- 데이터: [${arr.join(', ')}]\n- 분석 지표 ➔ 평균: ${mean.toFixed(1)}점 | 분산: ${variance.toFixed(2)} | 표준편차: √${variance.toFixed(2)} ≒ ${stddev.toFixed(2)}점\n- 데이터 분포 해석:\n이 자료는 표준편차가 ${stddev.toFixed(2)} 수준입니다. 평균값인 ${mean.toFixed(1)}점을 기준으로 데이터들이 골고루 밀집되어 분포해 있는지 혹은 멀리 퍼져 있는지 그래프를 보고 해석해 볼 수 있습니다.`;
    }

    function updateCustomDispersionChart(dataArray, meanValue) {
        if(customDispersionChart) {
            customDispersionChart.destroy();
        }

        const ctx = document.getElementById('customDispersionChart').getContext('2d');
        const sorted = [...dataArray].sort((a, b) => a - b);
        
        customDispersionChart = new Chart(ctx, {
            type: 'scatter',
            data: {
                datasets: [{
                    label: '입력 변량 개별 위치',
                    data: sorted.map((v, i) => ({ x: v, y: 1 })),
                    backgroundColor: '#10B981',
                    pointRadius: 8,
                    pointHoverRadius: 10
                }, {
                    label: '평균선',
                    data: [{ x: meanValue, y: 0.5 }, { x: meanValue, y: 1.5 }],
                    type: 'line',
                    borderColor: '#EF4444',
                    borderWidth: 2,
                    borderDash: [5, 5],
                    fill: false,
                    pointRadius: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: { title: { display: true, text: '수치 값' } },
                    y: { display: false, min: 0.5, max: 1.5 }
                }
            }
        });
    }

