    let scatterData = [];
    function loadScenario(type) {
        const tableBody = document.querySelector('#scatter-table tbody');
        tableBody.innerHTML = '';
        
        const thX = document.getElementById('th-x');
        const thY = document.getElementById('th-y');

        if(type === 'negative') {
            thX.innerText = "하루 게임 시간 (X축, 분)";
            thY.innerText = "수학 성적 (Y축, 점)";
            scatterData = [
                { id: "학생1", x: 120, y: 65 },
                { id: "학생2", x: 180, y: 45 },
                { id: "학생3", x: 30, y: 95 },
                { id: "학생4", x: 90, y: 80 },
                { id: "학생5", x: 150, y: 55 }
            ];
        } else {
            thX.innerText = "발 크기 (X축, mm)";
            thY.innerText = "수학 성적 (Y축, 점)";
            scatterData = [
                { id: "학생1", x: 230, y: 85 },
                { id: "학생2", x: 240, y: 55 },
                { id: "학생3", x: 270, y: 90 },
                { id: "학생4", x: 260, y: 70 },
                { id: "학생5", x: 250, y: 45 }
            ];
        }

        scatterData.forEach((row, i) => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${row.id}</td>
                <td><input type="number" value="${row.x}" class="table-x-val" style="width:80px; padding:6px;"></td>
                <td><input type="number" value="${row.y}" class="table-y-val" style="width:80px; padding:6px;"></td>
            `;
            tableBody.appendChild(tr);
        });

        if (document.getElementById('section3').classList.contains('active')) {
            updateScatterChart();
        }
    }

    function addTableRow() {
        const tableBody = document.querySelector('#scatter-table tbody');
        const nextNum = tableBody.children.length + 1;
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td>학생${nextNum}</td>
            <td><input type="number" value="100" class="table-x-val" style="width:80px; padding:6px;"></td>
            <td><input type="number" value="80" class="table-y-val" style="width:80px; padding:6px;"></td>
        `;
        tableBody.appendChild(tr);
    }

    function updateScatterChart() {
        const tableRows = document.querySelectorAll('#scatter-table tbody tr');
        const updatedData = [];
        tableRows.forEach(row => {
            const id = row.cells[0].innerText;
            const x = parseFloat(row.querySelector('.table-x-val').value) || 0;
            const y = parseFloat(row.querySelector('.table-y-val').value) || 0;
            updatedData.push({ id, x, y });
        });

        scatterData = updatedData;

        if(scatterChart) scatterChart.destroy();
        
        const ctx = document.getElementById('scatterChart').getContext('2d');
        scatterChart = new Chart(ctx, {
            type: 'scatter',
            data: {
                datasets: [{
                    label: '학생 데이터셋 분포',
                    data: scatterData.map(d => ({ x: d.x, y: d.y })),
                    backgroundColor: '#3B82F6',
                    pointRadius: 10,
                    pointHoverRadius: 12
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: { title: { display: true, text: 'X축 변량 수치' } },
                    y: { title: { display: true, text: 'Y축 변량 수치' } }
                }
            }
        });
    }

    function checkCorrelationAnswer() {
        const answer = document.getElementById('user-correlation-answer').value;
        const thXText = document.getElementById('th-x').innerText;
        
        if(!answer) return showModal("선택", "정답이라고 판정되는 상관관계를 선택해 주세요.");

        if(thXText.includes("게임 시간")) {
            if(answer === '음') {
                showModal("🎉 정답입니다!", "하루 동안 게임 시간이 늘어남에 따라 대체로 수학 성적은 줄어드는 오른쪽 아래 방향 흐름의 '음의 상관관계'가 나타납니다.");
            } else {
                showModal("❌ 오답입니다", "그래프의 점들이 오른쪽 아래로 기울며 내려가고 있는지 분석해 봅시다.");
            }
        } else {
            if(answer === '없음') {
                showModal("🎉 정답입니다!", "발 크기와 수학 성적은 규칙성 없이 흩어져 있어 어떠한 규칙성도 찾을 수 없는 '상관관계가 없음'에 해당합니다.");
            } else {
                showModal("❌ 오답입니다", "발 크기가 커질 때 올라가거나 떨어지는 양상이 확실히 보이고 있는지 다시 관찰하세요.");
            }
        }
    }

