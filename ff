    // [수정] 대푯값 선정 드롭다운 및 구체적 이유를 보고서 텍스트 상자(student-opinion-1)에 동적으로 병합하는 구조화 패치
    function calculateRepresentative() {
        const desc = document.getElementById('data-desc-1').value.trim() || "입력한 임의의 데이터";
        const inputVal = document.getElementById('data-input-1').value;
        
        let arr = inputVal.split(',').map(n => parseFloat(n.trim())).filter(n => !isNaN(n));
        if(arr.length === 0) return;

        const mean = (arr.reduce((a,b)=>a+b, 0) / arr.length).toFixed(1);
        
        arr.sort((a,b)=>a-b);
        let median = 0;
        const mid = Math.floor(arr.length / 2);
        if(arr.length % 2 === 0) {
            median = ((arr[mid - 1] + arr[mid]) / 2).toFixed(1);
        } else {
            median = arr[mid].toFixed(1);
        }

        const freq = {};
        arr.forEach(val => freq[val] = (freq[val] || 0) + 1);
        let maxFreq = 0;
        let modes = [];
        for(let key in freq) {
            if(freq[key] > maxFreq) {
                maxFreq = freq[key];
                modes = [key];
            } else if(freq[key] === maxFreq) {
                modes.push(key);
            }
        }
        const modeStr = modes.join(', ');

        document.getElementById('out-mean').innerText = parseFloat(mean);
        document.getElementById('out-median').innerText = parseFloat(median);
        document.getElementById('out-mode').innerText = modeStr;

        const repChoice = document.getElementById('representative-choice-1').value;
        const repReason = document.getElementById('representative-choice-reason-1').value.trim();
        const synthAns = document.getElementById('final-synthesis-question').value.trim();

        let finalOpinionText = `[나만의 데이터 실험 분석]\n- 자료: ${desc}\n- 원본값: [${arr.join(', ')}]\n- 분석 결과 ➔ 평균: ${parseFloat(mean)} | 중앙값: ${parseFloat(median)} | 최빈값: ${modeStr}\n`;
        
        if(repChoice) {
            finalOpinionText += `\n[우리 모둠 선정 대푯값]: ${repChoice}\n- 선정한 수학적 판단 이유:\n${repReason || "(판단 이유 미기재)"}\n`;
        }
        
        if (synthAns) {
            finalOpinionText += `\n[대푯값 성격 분석 종합 의견]\n${synthAns}`;
        }
        document.getElementById('student-opinion-1').value = finalOpinionText;
    }

