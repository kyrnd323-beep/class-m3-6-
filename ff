    function visualizeMedian() {
        const inputStr = document.getElementById('median-visual-input').value;
        const targetDiv = document.getElementById('median-step-by-step');
        
        let arr = inputStr.split(',').map(n => parseFloat(n.trim())).filter(n => !isNaN(n));
        if(arr.length === 0) {
            targetDiv.innerHTML = "<span style='color:red;'>숫자를 입력해 주세요! (예: 5, 12, 18...)</span>";
            return;
        }

        const origin = [...arr];
        arr.sort((a, b) => a - b);
        
        const n = arr.length;
        const isOdd = n % 2 !== 0;
        let median = 0;
        let explanation = "";

        if(isOdd) {
            const midIndex = Math.floor(n / 2);
            median = arr[midIndex];
            explanation = `
                <div style="margin-top: 10px; color: #6D28D9;">
                    <strong>📢 자료의 개수 분석: 홀수 개 (${n}개)</strong><br>
                    정확히 교과서 정의에 따라, 자료의 개수가 홀수이므로 <strong>중앙에 위치한 하나의 값</strong>을 그대로 중앙값으로 채택합니다.<br>
                    ➔ 중앙값: <strong style="font-size:1.15rem; color:var(--primary);">${median}</strong> (왼쪽에서 ${midIndex + 1}번째 위치)
                </div>
            `;
        } else {
            const midL = (n / 2) - 1;
            const midR = n / 2;
            median = (arr[midL] + arr[midR]) / 2;
            explanation = `
                <div style="margin-top: 10px; color: #6D28D9;">
                    <strong>📢 자료의 개수 분석: 짝수 개 (${n}개)</strong><br>
                    정확히 교과서 정의에 따라, 자료의 개수가 짝수이므로 <strong>중앙에 위치한 두 값의 평균</strong>을 계산하여 중앙값으로 삼습니다.<br>
                    ➔ 한가운데 of 두 값: ${arr[midL]} 와 ${arr[midR]}<br>
                    ➔ 두 값의 평균 계산: (${arr[midL]} + ${arr[midR]}) ÷ 2 ➔ 중앙값: <strong style="font-size:1.15rem; color:var(--primary);">${median}</strong>
                </div>
            `;
        }

        let sortedHtml = arr.map((val, idx) => {
            let isTarget = false;
            if (isOdd && idx === Math.floor(n/2)) isTarget = true;
            if (!isOdd && (idx === (n/2 - 1) || idx === (n/2))) isTarget = true;
            return `<span style="display:inline-block; padding: 6px 12px; margin: 3px; background:${isTarget ? '#C084FC':'#E2E8F0'}; color:${isTarget ? '#FFF':'#000'}; font-weight:bold; border-radius:6px; font-size: 1.1rem;">${val}</span>`;
        }).join(' ➔ ');

        targetDiv.innerHTML = `
            <div><strong>입력된 원본:</strong> [ ${origin.join(', ')} ]</div>
            <div style="margin: 10px 0;"><strong>크기순 정렬:</strong> ${sortedHtml}</div>
            <hr style="border:none; border-top: 1px solid #E2E8F0; margin:10px 0;">
            ${explanation}
        `;
    }

